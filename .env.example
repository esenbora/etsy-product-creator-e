# Image provider: 'fal' (default) | 'openrouter'
IMAGE_PROVIDER=fal

# fal.ai (default provider)
FAL_API_KEY=your-fal-key-here
# Optional model override (default: fal-ai/flux/dev/image-to-image)
# FAL_MODEL=fal-ai/recraft-v3

# OpenRouter (fallback / IMAGE_PROVIDER=openrouter ile aktif)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# Pinterest
# Etsy listing manager'da template/sample listing'i atlamak icin (kullanici kendi shop'unda override edebilir)
PINTEREST_TEMPLATE_LISTING_ID=4484014869
# Pinterest selector debug screenshot'lari: 1 = aktif (./screenshots/pin-debug-*.png)
DEBUG_PIN=0
