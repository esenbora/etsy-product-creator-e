{
  "name": "etsy-product-creator-e",
  "version": "3.16.6-e",
  "description": "AI-powered Etsy product creator: generate designs, compose mockups, scrape tags, upload listings",
  "main": "create.js",
  "scripts": {
    "start": "node server.js",
    "build:dist": "node scripts/build.js",
    "start:dist": "node dist/server.js",
    "browser:dist": "node dist/launch-browser.js",
    "create": "node create.js",
    "browser": "node launch-browser.js",
    "dev": "node launch-browser.js && node server.js",
    "x-digest": "node etsy-rules/_x-monitoring/x-digest.js",
    "holidays": "node etsy-rules/06-us-holidays/holiday-tracker.js",
    "rules-excel": "node etsy-rules/build-excel.js",
    "audit-health": "node audit-listing-health.js",
    "pnl": "node pnl.js",
    "scrape-customhub": "node scrape-customhub.js",
    "scrape-printnest": "node scrape-printnest.js",
    "scrape-ehunt": "node lib/scrape-ehunt.js",
    "diversification": "node diversification.js",
    "daily": "node daily-checklist.js",
    "weekly": "node weekly-review.js",
    "monthly": "node monthly-review.js",
    "holiday-gap": "node holiday-gap.js",
    "expiry-check": "node expiry-check.js",
    "listing-stats": "node scrape-listing-stats.js",
    "decay": "node detect-decay.js",
    "competitor-monitor": "node competitor-monitor.js",
    "auto-pin": "node auto-pin-new-listings.js",
    "license:mock": "node scripts/license-server-mock.js",
    "license:status": "node -e \"console.log(JSON.stringify(require('./lib/license').getStatus(), null, 2))\"",
    "doctor": "node scripts/doctor.js"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.24.0",
    "@imgly/background-removal-node": "^1.4.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2",
    "playwright": "^1.58.0",
    "sharp": "^0.33.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
